<li>
{%- assign tokens = {{page.section}} | split: ":" -%}
{%- assign open = false -%}
{%- for token in tokens -%}
  {%- if token == include.title -%}
    {%- assign open = true -%}
  {%- endif -%}
{%- endfor -%}
{%- if open -%}
<details open>
{%- else -%}
<details>
{%- endif -%}
<summary>{{include.title}}</summary>
<ul>
{%- if include.link -%}
<li><a href="{{include.link}}">{{include.title}}</a></li>
{%- endif -%}

{%- comment -%}
# vi:syntax=liquid
{%- endcomment -%}
