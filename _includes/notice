{%- comment -%}
Adds a stylized notice.
{%- endcomment -%}

{%- assign message = include.content | markdownify -%}
{%- assign notice-size = include.size -%}
{%- assign icon = include.icon -%}
{%- assign glyph = include.glyph -%}
{%- assign glyph-classes = include.class | default: "" -%}

{%- comment -%} Infer glyph from common icons. {%- endcomment -%}
{%- unless glyph -%}
  {%- capture glyph -%}
    {%- case icon -%}
      {%- when "tip"     -%} &#128161;
    {%- endcase -%}
  {%- endcapture -%}
{%- endunless -%}

{%- comment -%}
  Background and border colors are handled by CSS via the notice-{{icon}} class.
  Only apply inline overrides when explicit colors are passed as include params.
{%- endcomment -%}
{%- assign notice-icon-class = icon | default: "default" | strip -%}
{%- if notice-icon-class == "" -%}{%- assign notice-icon-class = "default" -%}{%- endif -%}
{%- capture font-size-style -%}{%- if notice-size -%}font-size: {{notice-size}}; {%- endif -%}{%- endcapture -%}
{%- capture inline-style -%}{{font-size-style}}{%- if include.background-color -%}background: {{include.background-color}}; {%- endif -%}{%- if include.highlight-color -%}border-left-color: {{include.highlight-color}}; {%- endif -%}{%- endcapture -%}
<div class="notice notice-{{notice-icon-class}}" style="{{inline-style}}">
  {%- if glyph != "" or glyph-classes != "" -%}
    <div class="notice-icon"><span class="{{glyph-classes}}">{{glyph}}</span></div>
  {%- elsif icon and icon != "" -%}
    {%- capture src -%} {%- include util/find-icon path=icon -%} {%- endcapture -%}
    {%- assign extension = src | slice: -4, 4 | downcase -%}
    {%- if extension == '.svg' -%}
      {%- comment -%} Vector images need an explicit width. {%- endcomment -%}
      <div class="notice-icon"><img src="{{src}}" width="32" alt=""></div>
    {%- else -%}
      <div class="notice-icon"><img src="{{src}}" alt=""></div>
    {%- endif -%}
  {%- endif -%}
  <div class="notice-content">{{message}}</div>
</div>

{%- comment -%}
# vi:syntax=liquid
{%- endcomment -%}
